{
  "expo": {
    "name": "wedjan",
    "slug": "wedjan",
    "version": "0.1.0",
    "scheme": "wedjan",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#f9f9f9"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.wedjan.app"
    },
    "android": {
      "package": "com.wedjan.app",
      "edgeToEdgeEnabled": true
    },
    "plugins": ["expo-router", "expo-secure-store"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
