# Normalize all text to LF in the repo and working tree — keeps the
# homepage freeze manifest stable across Windows/macOS/Linux checkouts.
* text=auto eol=lf

# Windows scripts need CRLF
*.bat text eol=crlf

# Binary assets
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.avif binary
*.gif binary
*.ico binary
*.jar binary
*.pdf binary
*.woff binary
*.woff2 binary
