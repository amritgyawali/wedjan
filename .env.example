# wedjan — environment variables
# Local dev works with zero configuration: docker compose provides Postgres,
# Redis, Mailpit and MinIO on the defaults below. Only override what you need.

# ---------------------------------------------------------------------------
# apps/api (Spring Boot)
# ---------------------------------------------------------------------------
DATABASE_URL=jdbc:postgresql://localhost:5432/wedjan
DATABASE_USER=wedjan
DATABASE_PASSWORD=wedjan
REDIS_HOST=localhost
REDIS_PORT=6379

# SMTP — Mailpit locally (UI at http://localhost:8025); Resend SMTP in prod
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM=wedjan <no-reply@wedjan.local>

# JWT signing secret — MUST be a long random string outside local dev
JWT_SECRET=dev-only-secret-change-me-dev-only-secret-change-me
# Set true behind HTTPS (production)
REFRESH_COOKIE_SECURE=false

# CORS — comma-separated allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081

# Object storage — MinIO locally, Cloudflare R2 in production
S3_ENDPOINT=http://localhost:9000
S3_REGION=auto
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=wedjan-media
MEDIA_PUBLIC_BASE_URL=http://localhost:9000/wedjan-media

# Dev seed (admin + demo accounts) — never enable in production
SEED_ENABLED=true
SEED_DEMO_PASSWORD=Demo@wedjan1

# ---------------------------------------------------------------------------
# apps/web (Next.js) — NEXT_PUBLIC_* are exposed to the browser
# ---------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8080

# ---------------------------------------------------------------------------
# apps/mobile (Expo) — EXPO_PUBLIC_* are exposed to the app
# For a physical device, use your machine's LAN IP instead of localhost.
# ---------------------------------------------------------------------------
EXPO_PUBLIC_API_URL=http://localhost:8080
